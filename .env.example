# Raindrop.io test token — get it from: https://app.raindrop.io/settings/integrations
RAINDROP_TOKEN=

# Collection ID — open your collection in raindrop.io, the number in the URL is the ID
# Use 0 to pull from ALL your bookmarks
RAINDROP_COLLECTION_ID=

# Server port (default: 3000)
PORT=3000

# Path to the SQLite database file (default: ./data/youtv.db)
# In Docker this is set to /app/data/youtv.db via the VOLUME mount
DB_PATH=./data/youtv.db
